# GEFO Frontend — copy to .env.local and fill in values
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Sentry (optional — error reporting + performance) ──────────
# Leave both DSNs empty to disable. Different DSNs for client vs server
# is recommended in production so you can scope quotas / projects separately.
# Browser (publicly exposed by Next.js — that's expected for DSNs):
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Server (Node + edge runtimes):
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
