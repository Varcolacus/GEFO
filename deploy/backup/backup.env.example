# Copy to /etc/gefo/backup.env and fill in real values. Restrict perms:
#   sudo chown root:gefo-backup /etc/gefo/backup.env
#   sudo chmod 640 /etc/gefo/backup.env

# Same connection string as backend/.env.
DATABASE_URL=postgresql://gefo_user:CHANGE_ME@localhost:5432/gefo_db

# Local directory where dumps are written. Will be created if missing.
BACKUP_LOCAL_DIR=/var/backups/gefo

# rclone remote name + path. Leave empty to keep backups local only.
# Configure the remote once with `rclone config` — Hetzner Storage Box,
# Backblaze B2, Wasabi, and AWS S3 all work. Example:
#   rclone config create hetzner s3 provider Other endpoint https://...
#   BACKUP_REMOTE=hetzner:gefo-backups
BACKUP_REMOTE=

# Keep this many days of local dumps. Remote retention is set on the
# bucket / lifecycle policy of the storage provider.
BACKUP_RETENTION_DAYS=30
