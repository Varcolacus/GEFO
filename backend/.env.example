# GEFO Backend Environment — copy to .env and fill in values

# ─── Core ───────────────────────────────────────────────────────
# "development" (default) | "staging" | "production". Production refuses to
# start unless JWT_SECRET_KEY and STRIPE_WEBHOOK_SECRET (if Stripe is on)
# are properly set — see backend/app/core/config.py validator.
ENV=development

DATABASE_URL=postgresql://gefo_user:gefo_password@localhost:5432/gefo_db
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000

# ─── Data sources ───────────────────────────────────────────────
UN_COMTRADE_API_KEY=
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2

# AIS vessel tracking — free signup at https://aisstream.io
AISSTREAM_API_KEY=
# Community AIS network (better Asian coverage) — https://www.aishub.net
AISHUB_USERNAME=

# ─── Auth (REQUIRED in production) ──────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE-ME-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Stripe (billing) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_INSTITUTIONAL_PRICE_ID=

# ─── SMTP (optional — email notifications) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@gefo.io
SMTP_USE_TLS=true

# ─── Sentry (optional — error reporting + performance) ──────────
# Leave blank to disable. Free tier at https://sentry.io is plenty for
# early-stage projects. DSN looks like https://abc@o123.ingest.sentry.io/456
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
