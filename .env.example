# GEFO Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ───
DB_PASSWORD=gefo_password
DATABASE_URL=postgresql://gefo_user:gefo_password@localhost:5432/gefo_db

# ─── Domain (for production — leave default for local) ───
DOMAIN=gefo.example.com

# ─── AIS Vessel Tracking (optional — without these, no vessels shown) ───
# Register free at https://aisstream.io
AISSTREAM_API_KEY=8791f87c306f76b2e244d0119548b52cd485b81c

# Register free at https://www.aishub.net
AISHUB_USERNAME=

# ─── UN Comtrade Trade Data (optional) ───
# Register at https://comtradeplus.un.org
UN_COMTRADE_API_KEY=
COMTRADE_KEY=

# ─── Security ───
SECRET_KEY=change-me-to-a-random-string
